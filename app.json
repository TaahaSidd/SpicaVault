{
  "expo": {
    "name": "SpicaVault",
    "slug": "SpicaVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.spicalabs.securevault",
      "edgeToEdgeEnabled": true,
      "allowBackup": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.MANAGE_MEDIA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0F"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "SpicaVault needs access to import media to your vault.",
          "savePhotosPermission": "SpicaVault needs access to save media to your vault.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-video",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-sqlite",
      "expo-screen-orientation",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3776614889739454~6224439329"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bb62cb3d-e768-4c64-bd68-8076ddfb680e"
      }
    }
  }
}